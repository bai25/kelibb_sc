# ============================================================
# 可堡灵之校 v2 - enrich 第1轮
# 丰富 w1d1 ~ w1d2 对话细节和选择分支
# 补充角色个性、氛围渲染、选择分支
#
# 使用方式：
#   Ren'Py 会自动加载所有 .rpy 文件，
#   在原有 flow 中 call 这些 label 即可扩展剧情。
#   所有新增 label 均以 enrich_ 前缀命名，避免冲突。
# ============================================================

# ============================================================
# w1d1 扩充 · 清晨宿舍细节
# 用于原有 w1d1_morning 中"他揉了揉眼睛，没有多想"之后
# call enrich_dorm_morning_detail
# ============================================================
label enrich_dorm_morning_detail:
    scene dorm_day
    with dissolve

    "吕文强下了床，赤脚踩在冰凉的地板上。"
    "宿舍里弥漫着一股隔夜的气味——汗味、旧书味、还有一点点方便面的调料味。"

    "他端起水杯。"
    "里面的水和昨晚一模一样——"
    "但他隐约记得，自己睡觉前明明把剩下的半杯倒掉了。"

    "他盯着杯里的水看了几秒。"
    "水面平静。没有气泡。"
    "就好像这杯水从来没有被动过。"

    lv "(……奇怪。)"

    "他放下杯子。"
    "决定做一件事。"

    menu enrich_dorm_choice:
        "在笔记本上留个记号——验证自己的记忆":
            $ has_noticed = True
            "他从抽屉里拿出笔，在自己的笔记本扉页画了一个小圆圈。"
            lv "如果明天这个圆圈不见了……那就是有人动过。"
            "他把笔记本放回原位。"
            "但这个念头一旦种下，就像一根刺一样扎在脑子里。"

        "对着杯子自言自语":
            "他站在水杯前，清了清嗓子。"
            lv "你——要是再乱跑，我就把你扔了。"
            "说完他自己都觉得荒谬。"
            "他在和一只杯子说话。"
            "但不知为何——说出口之后，心里那块石头轻了一些。"

        "直接去洗漱——想多了":
            "他甩了甩头。"
            "可能是昨晚没睡好。"
            "校园生活就是这样——大脑会在疲劳时产生一些奇怪的错觉。"
            "他把这件事抛在脑后，走进了洗手间。"

    "水龙头拧开的时候发出刺耳的摩擦声。"
    "冷水拍在脸上——凉意让他清醒了一些。"
    "他抬起头，看向镜子。"

    "镜子里的自己——"
    "没什么异常。"
    "但就在他低下头的那一刻，他余光瞥到——"
    "镜子里好像有个人影，站在他身后。"

    "他猛地回头。"

    "洗手间里只有他一个人。"

    "水滴还在从水龙头口往下落。"
    "滴答。滴答。"
    "他深吸一口气。"

    lv "……真的没睡好。"

    return


# ============================================================
# w1d1 扩充 · 教室中的选择
# 用于原有 w1d1_morning 教室段落，
# 在"你压下心里的那点异样，开始自习"之后
# call enrich_classroom_choice
# ============================================================
label enrich_classroom_choice:
    scene classroom_day
    with dissolve

    "你翻开课本。"
    "字迹确确实实是你的——但那些内容，你一点印象都没有。"

    "你盯着那几行字看了很久。"
    "笔迹的收尾处有一个习惯性的小勾——那是你写字的特点。"
    "模仿不了的那种。"

    lv "(是我写的……但我完全不记得。)"
    lv "这算什么——梦游的时候爬起来学习？"

    menu enrich_classroom_mood:
        "和同桌搭话——试探他":
            "你侧过头。"
            lv "哎，昨天下午最后一节是什么课来着？"
            "同桌头也不抬。"
            classmate_a "数学啊。你自己上的课你不知道？"
            lv "……我记得是语文。"
            "同桌终于抬起头。他看了你一眼——"
            "那个眼神让你很不舒服。"
            "不是恶意。"
            "是那种……看一个突然说胡话的人的眼神。"
            classmate_a "你没事吧？昨天下午第三节就是数学。"
            classmate_a "你是不是学傻了？"
            lv "……可能吧。"
            "你转回去。"
            "但你很清楚——昨天下午第三节，是语文。"

        "看窗外发呆——尝试理清思路":
            "你把目光移向窗外。"
            "操场上有人在打篮球。"
            "阳光很好。一切都那么正常。"
            "正常到不正常。"
            "你盯着窗外——"
            "然后你注意到一个细节。"
            "楼下篮球场上，那个投篮的人——"
            "他已经连续投了六个球了。"
            "每一个都进了。"
            "而且——他的动作一模一样。"
            "速度、角度、起跳的高度——完全一致。"
            "像播放同一段录像。"
            lv "(……太准了吧。)"
            "你把目光收回来。没有深想。"

        "翻到被折角的那页——仔细研究":
            "你重新翻到被折角的那一页。"
            "是课本中间的一幅插图。"
            "学校的俯瞰图。"
            "你仔细看了看图上标注的文字——"
            "大部分都很正常：教学楼、宿舍、食堂、操场。"
            "但在操场北边——"
            "有一个区域没有被标注。"
            "空白的。没有任何文字。"
            "但在老版本的地图上，那里应该是一座旧的实验楼。"
            lv "实验楼……被拆了？"
            "你不确定。"
            "你来这个学校三年了——从没注意过操场北边有什么。"
            "但你突然意识到：你从来没有往那个方向走过。"
            "为什么？"
            $ has_noticed = True

    return


# ============================================================
# w1d1 扩充 · 食堂互动
# 在原有午餐对话后扩充
# call enrich_canteen_interaction
# ============================================================
label enrich_canteen_interaction:
    scene canteen_day
    with dissolve

    "你扒了一口饭。"
    "西红柿炒蛋——有点凉了。"
    "食堂的菜总是这样。算不上难吃，但也绝对谈不上好吃。"

    "旁边那桌还在聊。"

    classmate_a "……所以你说，那六个代表是干嘛的？"
    classmate_b "不知道。但听说不是随便选的——"
    classmate_a "什么意思？"
    classmate_b "我表姐在学生会，她说名单是校长亲自定的。"
    classmate_b "班主任都没有过问权。"
    classmate_a "校长亲自？以前不都是各班推选吗？"
    classmate_b "所以我说——这次不一样。"

    menu enrich_canteen_response:
        "端着餐盘坐过去——加入对话":
            "你端着餐盘站起来。"
            "走到那桌旁边。"
            lv "不好意思——刚才听你们说学生代表的事——"
            "两个人同时抬头看你。"
            classmate_a "哦，你是三班的吧？"
            lv "对。你们说的校长亲自定名单……是真的？"
            classmate_b "我表姐说的。她没必要骗我。"
            classmate_b "而且她说——"
            "他压低声音。"
            classmate_b "名单上的六个人，每一个都是校长单独找过的。"
            classmate_b "没有经过任何评选流程。"
            "你感到后背微微一凉。"
            lv "……校长找过他们？"
            classmate_b "至少我表姐是这么说的。"
            classmate_b "具体说了什么——她也不知道。"
            lv "谢了。"
            "你端着餐盘回到自己的位置。"
            "饭菜已经彻底凉了。"
            "但你忽然没什么胃口了。"
            $ has_noticed = True

        "继续吃自己的——不多管闲事":
            "你低下头继续吃饭。"
            "学生代表的事和你没什么关系。"
            "你既不是成绩拔尖的那种，也不是学生会的人。"
            "怎么也轮不到你。"
            "你把注意力放回餐盘里。"
            "但耳朵还是不由自主地竖着——"
            "那桌的对话还在继续。"
            classmate_b "反正啊——这次春游有点怪。"
            classmate_a "哪里怪？"
            classmate_b "说不清……就感觉……太突然了。"
            classmate_b "学校这么久没组织过校外活动了，突然就要搞春游——"
            classmate_b "还选什么学生代表。"
            classmate_a "你想多了吧。"
            classmate_b "也许吧。"
            "他们的对话被餐盘的碰撞声淹没了。"
            "但「太突然了」这四个字，在你脑子里转了很久。"

    return


# ============================================================
# w1d1 扩充 · 傍晚宿舍深度互动
# 在原有傍晚对话后扩充
# call enrich_dorm_evening
# ============================================================
label enrich_dorm_evening:
    scene dorm_dusk
    with dissolve

    "晚上。宿舍。"
    "日光灯发出嗡嗡的响声。"
    "室友们各自忙着自己的事。"

    "上铺的哥们戴着耳机，在看手机视频——声音漏了出来，是搞笑视频的罐头笑声。"
    "对面床的室友在打电话——口气温柔，一听就是打给女朋友的。"
    "还有一个坐在书桌前，面前摊着一本练习册——但笔尖半天没动一下。"

    "你们六个人一间宿舍，住了快两年。"
    "你了解他们的习惯、他们的作息、他们说梦话时的内容。"
    "但今天——"
    "你忽然觉得，这个住了两年的房间，有点陌生。"

    menu enrich_dorm_evening_choice:
        "主动聊起春游的事":
            lv "哎——你们说春游会去哪儿？"
            "室友乙从手机上抬起头。"
            roommate_2 "不知道啊，但只要有假放就行。去哪儿无所谓。"
            roommate_1 "我听说森林公园那个方案被毙了——太远了。"
            roommate_1 "可能就在附近的景点转一圈。"
            lv "……那选学生代表干嘛？"
            "房间里安静了一秒。"
            roommate_2 "谁知道呢。摆拍吧。学校就喜欢搞这套。"
            "他的语气很轻描淡写。"
            "但你注意到，他说这话的时候，眼睛没有离开手机屏幕。"
            "像是——不想在这个话题上多聊。"

        "试探室友对「异常」的感受":
            lv "你们有没有觉得……今天哪儿不太对？"
            "室友乙抬起头。"
            roommate_2 "不对？哪里不对？"
            lv "就是……说不上来。"
            roommate_1 "你发烧了？"
            lv "没有——就是感觉。"
            roommate_2 "那你可能是春游兴奋过头了。"
            roommate_2 "赶紧睡吧，明天还要上课。"
            "他们显然不觉得有什么异常。"
            "但你的直觉告诉你——不是你在多想。"
            "是有什么东西……在所有人都没注意的时候，已经悄悄地变了。"

    "夜深了。"
    "室友们陆续关灯上床。"
    "最后一个关灯的人是你。"

    "啪嗒。"
    "房间陷入黑暗。"

    "你躺在黑暗中。"
    "天花板上映着窗外路灯投进来的光斑。"
    "像一只半睁的眼睛。"

    return


# ============================================================
# w1d1 扩充 · 深夜梦境（新增）
# 在 w1d1 结束跳转 w1d2 之前插入
# call enrich_dream_sequence
# ============================================================
label enrich_dream_sequence:
    scene black
    with dissolve

    "你睡着了。"

    "——或者说，你以为你睡着了。"

    scene black
    with dissolve

    "你站在一个不认识的地方。"

    "四周是白色的——不是雾，是一种没有边界的白。"
    "脚下没有地面，但你确实站在什么东西上面。"
    "你低头——看不到自己的脚。"

    "远处有一个声音。"
    "不是说话声——更像是某种节奏。"
    "咚。咚。咚。"
    "像心跳。又像鼓点。"

    "然后你看到了一个轮廓。"

    "一个人影——不，不是人。"
    "太高了。太瘦了。轮廓的边缘在白色中微微颤动，像是被什么东西拉扯着。"

    "它——或者说他——站在你面前不远处。"
    "他的脸上……"

    "是一张面具。"

    "纯白的面具。没有五官。"
    "但你能感觉到——它在看你。"

    mask "……来了啊。"

    "他的声音从面具后面传出来——"
    "像从很远的地方传来，又像紧贴在你的耳边。"

    "你想开口——但发不出声音。"

    mask "不用说话。"
    mask "我只是……来看看你。"
    mask "看看这六个里面——"
    mask "谁比较有趣。"

    "他抬起手。"
    "那只手——也是白色的，五根手指异常地长。"
    "他指向你——"

    mask "你。"

    "然后他的手指移开，指向你身后的虚无——"

    mask "你。"
    mask "你。"
    mask "你。"
    mask "你。"
    mask "你。"

    "他数了六下。"

    mask "六个人。"
    mask "够了。"

    "他收回手。"
    "白色面具上——慢慢裂开一道缝。"
    "像一张嘴——"
    "在笑。"

    mask "我们很快会见面的。"
    mask "吕文强。"

    "——"

    "你猛地睁开眼。"

    scene dorm_night
    with dissolve

    "天还没亮。"
    "宿舍里一片漆黑。"
    "你的心脏在胸腔里疯狂跳动，像刚跑完一千米。"

    "你坐起来。"
    "浑身是汗。"

    "梦。"
    "只是一个梦。"

    "但你清晰地记得——"
    "那个面具。"
    "那六个指向。"
    "还有那句「我们很快会见面的」。"
    "每一个细节都像烙印一样刻在你的脑子里。"

    "你看向窗外。"
    "夜色很深。"
    "但月光很亮——亮得不正常。"

    "你在黑暗中坐了很久。"
    "直到心跳平复。"
    "直到困意再次将你淹没。"

    scene black
    with fade

    "你再次睡着了。"
    "这一次——没有梦。"

    $ has_noticed = True

    return


# ============================================================
# w1d2 扩充 · 六人初遇个性化对话
# 在原有六人初遇段落中，各角色的深度对话
# call enrich_six_intro_deep
# ============================================================
label enrich_six_intro_deep:
    scene office_principal
    with dissolve

    "六个人在校长办公室里等着。"
    "时间一分一秒地过去。"
    "有人开始不耐烦了——有人在安静地观察——有人在发呆。"

    "你扫视了一圈这个房间。"
    "除了你们六个人，房间里最显眼的就是那张巨大的办公桌。"
    "桌面上很整洁——只有一个笔筒、一个台历、一台关闭的电脑。"
    "但台历翻开的不是今天的日期。"
    "是三天前的。"

    "你正想出声提醒其他人——"

    show xhh normal at sprite_center
    with dissolve

    xhh "我说——"
    xhh "你们不好奇吗？"
    xhh "为什么是我们六个？"

    "徐鸿昊第一个打破了沉默。"

    hide xhh with dissolve
    show zwh sneaky at sprite_center
    with dissolve

    zwh "好奇有用吗？"
    zwh "校长把我们叫来，自己又不在——"
    zwh "要么是下马威，要么……"
    "他顿了顿。"
    zwh "要么是出了什么事。"

    hide zwh with dissolve
    show yjc normal at sprite_center
    with dissolve

    yjc "学校能出什么事。"
    "严笳谌的声音很平——像在陈述一个不容置疑的事实。"
    yjc "大概是临时会议拖延了。"
    "她推了推眼镜。"

    hide yjc with dissolve
    show wjy normal at sprite_center
    with dissolve

    "吴机岩从墙边直起身来。"
    wjy "拖延？"
    wjy "那为什么没人来通知？"
    wjy "穿堂风都没有。"

    "他的话简短——但掷地有声。"

    hide wjy with dissolve
    show xhh happy at sprite_center
    with dissolve

    xhh "哈哈——我开始觉得有意思了。"

    hide xhh with dissolve
    show ld normal at sprite_center
    with dissolve

    "一直沉默的劳达开口了。"
    ld "安静。"

    "只有两个字。"
    "但办公室里立刻静了下来。"

    ld "听。"

    "所有人屏住呼吸。"

    "——安静。"
    "不是普通的安静。"
    "是那种……没有背景音的安静。"

    "没有走廊上的脚步声。"
    "没有远处操场上体育老师的哨声。"
    "没有隔壁办公室的电话铃声。"
    "什么都没有。"

    ld "……正常吗？"

    "他看向你。"

    menu enrich_silence_reaction:
        "不正常——学校从来没有这么安静过":
            lv "不正常。"
            lv "这个点——应该是课间操时间。"
            lv "外面应该有广播声、有学生跑动的声音。"
            lv "但什么都没有。"
            "你这话一出口——其他人的表情都变了。"
            "徐鸿昊的笑容收了起来。"
            "严笳谌扶眼镜的手停在半空。"
            "吴机岩的眉头皱了起来。"
            $ has_noticed = True

        "也许是我们多心了":
            lv "可能……今天课间操取消了吧。"
            zwh "课间操取消？那上课铃声呢？"
            zwh "你听到铃声了吗？"
            "他说得对。"
            "你努力回忆——"
            "从你们进入行政楼到现在，没有听过一次铃声。"
            "但现在是上课时间。"
            $ has_noticed = True

    hide ld with dissolve
    show zwh sneaky at sprite_center
    with dissolve

    zwh "所以我说——"
    zwh "出去看看不就知道了？"

    "他的目光扫过所有人。"
    "最终——落在你身上。"

    zwh "怎么样，三班的？"
    zwh "敢不敢？"

    "所有人的目光再次聚焦在你身上。"

    return


# ============================================================
# w1d2 扩充 · 校长室调查
# 在等待时可以调查房间
# call enrich_office_investigation
# ============================================================
label enrich_office_investigation:
    scene office_principal
    with dissolve

    "既然校长不在——不如趁机看看这个房间。"

    menu enrich_office_search:
        "检查办公桌":
            "你走到校长的办公桌前。"
            "桌面很整洁——整洁得有些不自然。"
            "笔筒里的笔全部朝同一个方向。"
            "台历——翻到三天前。"
            "你翻了翻台历——上面没有任何备注。"
            "但有一页的角落——画了一个小小的符号。"
            "一个圆圈里面打了个叉。"
            "像是某种标记。"
            $ has_noticed = True

        "检查书柜":
            "你走到书柜前。"
            "玻璃柜门没有锁。你拉开它——"
            "书很整齐。按字母排序。教育类书籍占了大部分。"
            "但最下层有一本书的摆放方向和其他不同——"
            "它被反过来放了。书脊朝内。"
            "你抽出来。"
            "封面是空白的。白色硬壳。没有任何标题。"
            "你翻开——"
            "全白。每一页都是空白的。"
            "但翻到最后一页的时候——"
            "你看到一行字。手写的。"
            "「不要翻开这一页。」"
            "你翻开了。你说晚了。"
            lv "……谁会在空白书上写这种东西？"
            "你把书放回去。"
            "手指碰到书脊的时候——有一种黏腻的触感。"
            "你没有细想。"

        "打量其他五个人——观察他们的反应":
            "你没有动房间里的东西。"
            "而是把目光投向其他五个人。"
            "徐鸿昊——靠在沙发上，看似放松，但脚尖在轻轻点地。他在紧张。"
            "严笳谌——站在窗边，背对着所有人。她一直在看窗外。"
            "吴机岩——靠着书架，手指在裤缝上打着拍子。节奏很稳。他可能在数数。"
            "张闻晦——靠在另一边的墙上，嘴角带着一丝笑意。他显然知道什么——或者自以为知道什么。"
            "劳达——站在门边。他那个位置可以看到门口和窗户两个方向。"
            lv "(这个站位——像是下意识的防御位置。)"

    "你收回注意力。不管找到什么——眼下最重要的，是搞清楚外面的情况。"

    return


# ============================================================
# w1d2 扩充 · 空走廊的细节
# 在走出办公室后，走廊的深入描写
# call enrich_empty_corridor
# ============================================================
label enrich_empty_corridor:
    scene corridor_day
    with dissolve

    "你走进了走廊。"

    "日光灯依旧亮着。发着惨白的光。"
    "你注意到——走廊两侧所有的教室门都关着。"
    "但有些门缝下面——透出了光。"

    "如果有光——里面应该有人。"

    "你走到离你最近的一扇门前。"
    "蹲下来——从门缝里看进去。"

    "里面——"

    "是空的。"

    "灯开着。风扇在转。"
    "黑板上写着板书。课桌上摊着书本。"
    "但没有一个人。"

    "就像是所有人同时站了起来——走出了教室——"
    "而没有人负责关灯或者关风扇。"

    "你站起身。"
    "手心有一点出汗。"

    "你继续往前走。"
    "走廊的尽头是一扇窗户——窗外就是操场。"
    "你靠近窗户——"

    scene playground
    with dissolve

    "你看到了和昨天一样的东西。"
    "空荡荡的操场。"
    "但今天——旗杆上的旗子不见了。"
    "只剩一根光秃秃的旗杆。"
    "像一根被拔掉指甲的手指。"

    "你凝视着操场。"
    "视野的边缘——好像有什么东西在动。"
    "你转头——"
    "什么都没有。"
    "但你的直觉告诉你——你被什么东西注视着。"

    "你回过头。"
    "走廊的另一头——"
    "张闻晦不知什么时候跟了出来。"
    "他站在走廊中间，远远地看着你。"

    $ has_noticed = True

    return


# ============================================================
# w1d2 扩充 · 广播后的异常课堂细节
# 在广播后、学生返回教室后的深度描写
# call enrich_post_broadcast_classroom
# ============================================================
label enrich_post_broadcast_classroom:
    scene classroom_day
    with dissolve

    "教室里恢复了「正常」。"
    "老师站在讲台上，翻开了教案。"
    "同学们翻开课本。笔尖落在纸上。"
    "一切都对——"
    "但一切都不对。"

    "你坐在座位上。"
    "握着笔。"
    "但一个字都写不出来。"

    "你偷偷观察着四周。"

    "前排的女同学——她的笔在动。一字一句地抄着板书。"
    "但她抄写的内容和黑板上写的——完全不一样。"
    "她在写一排重复的数字。"
    "'5、8、13、5、8、13……'"
    "看起来毫无意义——但她写得很认真，像是在完成什么神圣的任务。"

    "你移开目光。"
    "看向右侧隔了两排的男生——"
    "他一直在点头。"
    "不是那种「听得懂」的点头。"
    "是那种匀速的、机械的、一下接一下的——"
    "像一个节拍器。"
    "一秒一下。从不间断。"

    "你的心跳开始加速。"

    "你看向讲台上的老师。"
    "她也在讲课——嘴唇在动，声音传出来——"
    "但她的眼神……"
    "不像是在看学生。"
    "像是在看着空无一人的教室，完成一场排练好的表演。"

    show lv fright at sprite_center
    with dissolve

    lv "(这一切……都是演出来的。)"

    "你低下头。"
    "强迫自己看向课本。"
    "你的手在发抖。"

    "同桌的笔停了。"
    "他转过头——"
    "用那双空洞的眼睛看着你。"

    classmate_a "你怎么不写了？"

    "他的声音很平静。"
    "平静得让人毛骨悚然。"

    menu enrich_post_broadcast_reaction:
        "「我手有点酸，休息一下」":
            "你尽量让自己的声音听起来自然。"
            lv "写太多了……手酸。"
            "同桌看了你两秒。"
            classmate_a "哦。"
            "他转回去了。"
            "但你知道——"
            "他不相信你。"
            "或者说——"
            "他根本不在乎你写了什么。"
            "他只是按照某种设定好的程序，问了一个问题。"
            "得到答案后——程序继续运行。"

        "反问他——「你怎么了？」":
            "你直视他的眼睛。"
            lv "你才是——你还好吗？"
            "同桌愣了一下。"
            "就是那个瞬间——他的眼神里出现了一丝波动。"
            "像是水面被投进了一颗石子。"
            classmate_a "……我？"
            classmate_a "我很好啊。"
            "他说「我很好啊」——"
            "但他的语气里有一种不确定。"
            "就像他自己也不确定自己是不是真的「很好」。"
            "然后那丝波动消失了。"
            "他的眼神又恢复了那种空洞的平静。"
            classmate_a "好好听课吧。"
            "他转了回去。"

    "你重新低下头。"
    "握着笔的手心全是汗。"

    "你看了看窗外——"
    "天空是那种不正常的惨白色。"
    "校园里一片寂静。"
    "教室里只有写字的声音。"
    "但这些沙沙声——"
    "在你听来，像是一种低语。"
    "像是一群人在整齐地念着什么——"
    "只是音量太小，你听不清。"

    "你用力摇了摇头。"
    "把那个念头甩出去。"

    "但声音还在。"

    "沙沙沙沙——"
    "沙沙沙沙——"
    "沙沙沙沙——"

    $ has_noticed = True

    return


# ============================================================
# w1d2 扩充 · 傍晚过渡
# 在 w1d2 结束前插入反思时刻
# call enrich_d1d2_evening_reflection
# ============================================================
label enrich_d1d2_evening_reflection:
    scene dorm_dusk
    with dissolve

    "一天结束了。"

    "你躺在宿舍的床上。"
    "天花板上的裂缝在昏暗中看起来更深了。"

    "你今天经历了很多。"
    "学生代表。空无一人的校园。封锁的校门。"
    "广播。回来的同学们。"
    "那张潦草的纸条——「不要相信广播。」"

    "你闭上眼睛——"

    $ doc_count = 0
    if has_noticed:
        $ doc_count += 1

    if doc_count > 0:
        "今天之前，你觉得学校生活无聊——日复一日，枯燥乏味。"
        "今天之后……"
        "你只希望回到那个无聊的日子。"
        "但你知道——"
        "回不去了。"

    "你翻了个身。"
    "闭上眼睛。"

    "明天——"
    "会发生什么？"

    scene black
    with fade

    $ has_noticed = True

    return


